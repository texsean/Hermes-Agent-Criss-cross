{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Default": "Data Source=/data/inventorybuddy/inventory.db"
  },
  "ImageStorage": {
    "BasePath": "/data/inventorybuddy/images",
    "MaxImageSizeBytes": 5242880
  },
  "ChangeDetection": {
    "DiffThreshold": 0.15,
    "MinChangedPixels": 500
  },
  "Alerts": {
    "StaleItemDays": 3,
    "CameraOfflineMinutes": 60
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      }
    }
  }
}
